{
  "name": "portfolio-restored",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync": "node scripts/sync-layers.js",
    "build": "node scripts/sync-layers.js && vite build && node scripts/copy-404.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "translate": "node scripts/update-translations.js",
    "validate:translations": "node scripts/update-translations.js --validate"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.409",
    "@remotion/player": "^4.0.409",
    "framer-motion": "^10.16.4",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "phosphor-react": "^1.4.1",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.13.0",
    "remotion": "^4.0.409"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "eslint-plugin-unused-imports": "^4.4.1",
    "google-translate-api-x": "^10.7.2",
    "postcss": "^8.4.31",
    "puppeteer": "^24.40.0",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  },
  "reactSnap": {
    "source": "dist",
    "ignore": [
      "/color-rules.html",
      "/design-system.html"
    ],
    "include": [
      "/",
      "/experience",
      "/case-studies",
      "/my-story",
      "/metrics"
    ],
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ]
  }
}
